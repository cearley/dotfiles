{{ if .has_keepassxc_db -}}
#!/bin/bash
cat <<'EOF'
{{ if has "dev" .tags -}}
[default]
aws_access_key_id = {{ keepassxcAttribute "AWS (DI Dev)" "aws_access_key_id" }}
aws_secret_access_key = {{ keepassxcAttribute "AWS (DI Dev)" "aws_secret_access_key" }}

[ces]
aws_access_key_id = {{ keepassxcAttribute "AWS (CES)" "aws_access_key_id" }}
aws_secret_access_key = {{ keepassxcAttribute "AWS (CES)" "aws_secret_access_key" }}

[di-dev]
aws_access_key_id = {{ keepassxcAttribute "AWS (DI Dev)" "aws_access_key_id" }}
aws_secret_access_key = {{ keepassxcAttribute "AWS (DI Dev)" "aws_secret_access_key" }}

[di-prod]
aws_access_key_id = {{ keepassxcAttribute "AWS (DI Prod)" "aws_access_key_id" }}
aws_secret_access_key = {{ keepassxcAttribute "AWS (DI Prod)" "aws_secret_access_key" }}
aws_session_token = {{ keepassxcAttribute "AWS (DI Prod)" "aws_session_token" }}

[personal]
aws_access_key_id = {{ keepassxcAttribute "AWS (Personal)" "aws_access_key_id" }}
aws_secret_access_key = {{ keepassxcAttribute "AWS (Personal)" "aws_secret_access_key" }}

[localstack]
aws_access_key_id = test
aws_secret_access_key = test
{{ else -}}
[default]
aws_access_key_id = {{ keepassxcAttribute "AWS (Personal)" "aws_access_key_id" }}
aws_secret_access_key = {{ keepassxcAttribute "AWS (Personal)" "aws_secret_access_key" }}
{{ end -}}
# --- end managed ---
EOF

existing=$(cat)
tail=$(echo "$existing" | awk '/^# --- end managed ---/{found=1; next} found{print}')
if [[ -n "$tail" ]]; then
  printf '%s\n' "$tail"
fi
{{ end -}}
