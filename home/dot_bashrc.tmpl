{{ if has "dev" .tags -}}
# SML/NJ - Standard ML of New Jersey - https://www.smlnj.org/dist/working/110.99.9/index.html
#export PATH=/usr/local/smlnj/bin:"$PATH"
# AWS bash completion
complete -C "$HOMEBREW_PREFIX/bin/aws_completer" aws
# AWS cli for use with LocalStack. (See https://github.com/localstack/awscli-local#alternative.)
alias awslocal="AWS_ACCESS_KEY_ID=test AWS_SECRET_ACCESS_KEY=test AWS_DEFAULT_REGION=${DEFAULT_REGION:-$AWS_DEFAULT_REGION} aws --endpoint-url=http://${LOCALSTACK_HOST:-localhost}:4566"
. "$HOME/.cargo/env"
# Load nvm
export NVM_DIR="$([ -z "${XDG_CONFIG_HOME-}" ] && printf %s "${HOME}/.nvm" || printf %s "${XDG_CONFIG_HOME}/nvm")"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh" # This loads nvm
{{- end }}

{{ if (has "ai" .tags) -}}
# Claude Code with Bedrock
claude-bedrock() {
    CLAUDE_CONFIG_DIR="$HOME/.claude-bedrock" command claude "$@"
}
claude-personal() {
    CLAUDE_CONFIG_DIR="$HOME/.claude-personal" command claude "$@"
}
claude-work() {
    CLAUDE_CONFIG_DIR="$HOME/.claude-work" command claude "$@"
}
{{- $claudeDefault := includeTemplate "machine-config" (merge (dict "setting" "claude_default") .) }}
{{- if $claudeDefault }}
alias claude='{{ $claudeDefault }}'
{{- end }}
# SpecStory https://specstory.com/specstory-cli
{{ if $claudeDefault -}}
claude-spec() {
    CLAUDE_CONFIG_DIR="$HOME/.{{ $claudeDefault }}" specstory run claude --no-cloud-sync "$@"
}
{{- else -}}
alias claude-spec='specstory run claude --no-cloud-sync'
{{- end }}
alias claude-bedrock-spec='CLAUDE_CONFIG_DIR=$HOME/.claude-bedrock specstory run claude --no-cloud-sync'
alias claude-personal-spec='CLAUDE_CONFIG_DIR=$HOME/.claude-personal specstory run claude --no-cloud-sync'
alias claude-work-spec='CLAUDE_CONFIG_DIR=$HOME/.claude-work specstory run claude --no-cloud-sync'
alias codex-spec='specstory run codex --no-cloud-sync'
alias gemini-spec='specstory run gemini --no-cloud-sync'
alias openspecui='npx openspecui@latest'

# Added by LM Studio CLI (lms)
export PATH="$PATH:{{- .chezmoi.homeDir -}}/.cache/lm-studio/bin"
export PATH="$PATH:{{- .chezmoi.homeDir -}}/.lmstudio/bin"
# End of LM Studio CLI section
{{- end }}

# direnv - Load/unload environment variables based on $PWD
eval "$(direnv hook bash)"

# Astral.sh uv - Python package manager
. "$HOME/.local/bin/env"
eval "$(uv generate-shell-completion bash)"
eval "$(uvx --generate-shell-completion bash)"
