{{- if and (eq .chezmoi.os "darwin") (has "dev" .tags) -}}
#!/bin/bash

# run_onchange trigger - packages.yaml changes or every 30 days:  {{ includeTemplate "time-bucket" (dict "days" 30) }}

set -euo pipefail

source "{{ .chezmoi.sourceDir -}}/scripts/shared-utils.sh"

if package_layer_should_skip "cargo"; then
    print_message "skip" "Skipping Cargo package updates for this run"
    exit 0
fi

source "{{ .chezmoi.homeDir -}}/.cargo/env"

if ! require_tools cargo rustup; then
    exit 1
fi

print_message "info" "Updating Rust toolchain..."
rustup update

print_message "info" "Installing cargo packages..."
# Bulk update all installed cargo packages first
cargo install cargo-update
cargo install-update -a
{{- $groups := includeTemplate "package-layer-items" (merge (dict "key" "cargo" "includeCore" false) .) | fromJson }}
{{- range $groups }}
# Install {{ .category }} cargo packages
{{ range .items -}}
cargo install {{ . }}
{{ end -}}
{{- end }}

print_message "success" "Cargo packages installed."

{{ end -}}
