{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

# run_onchange trigger - packages.yaml changes or every 7 days:  {{ includeTemplate "time-bucket" (dict "days" 7) }}

set -euo pipefail

source "{{ .chezmoi.sourceDir -}}/scripts/shared-utils.sh"

if package_layer_should_skip "bun"; then
    print_message "skip" "Skipping Bun package updates for this run"
    exit 0
fi

if ! require_tools bun; then
    exit 1
fi

print_message "info" "Installing global packages using bun..."
# Update outdated dependencies first
bun update -g
{{- $groups := includeTemplate "package-layer-items" (merge (dict "key" "bun") .) | fromJson }}
{{- range $groups }}
# Install {{ .category }} bun packages
{{ range .items -}}
bun add -g {{ . }}
{{ end -}}
{{- end }}

{{ end -}}
