{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

# run_onchange trigger - packages.yaml changes or every 7 days:  {{ includeTemplate "time-bucket" (dict "days" 7) }}

set -euo pipefail

source "{{ .chezmoi.sourceDir -}}/scripts/shared-utils.sh"

if package_layer_should_skip "homebrew"; then
    print_message "skip" "Skipping Homebrew package updates for this run"
    exit 0
fi

if ! require_tools brew; then
    exit 1
fi

print_message "info" "Installing packages using Homebrew..."

{{ $icloudAccountId := includeTemplate "icloud-account-id" . | trim -}}
{{ $icloudSignedIn := ne $icloudAccountId "" -}}
{{ if not $icloudSignedIn -}}
print_message "warning" "Not signed into iCloud - Mac App Store packages will be skipped"
{{ end -}}

{{- $tapGroups := includeTemplate "package-layer-items" (merge (dict "key" "taps") .) | fromJson -}}
{{- $brewGroups := includeTemplate "package-layer-items" (merge (dict "key" "brews") .) | fromJson -}}
{{- $caskGroups := includeTemplate "package-layer-items" (merge (dict "key" "casks") .) | fromJson -}}
{{- $masGroups := includeTemplate "package-layer-items" (merge (dict "key" "mas") .) | fromJson -}}
{{- $envGroups := includeTemplate "package-layer-items" (merge (dict "key" "brew_env") .) | fromJson -}}

# Pre-tap all required sources before brew bundle runs.
# brew bundle's fetch/validation phase checks casks before tap declarations
# in the Brewfile are processed, which fails on fresh machines where the
# tap is not yet registered.
print_message "info" "Adding Homebrew taps..."
{{- range .packages.darwin.taps }}
{{ if has . $.packages.darwin.trusted }}brew trust {{ . | quote }} && {{ end -}}
brew tap {{ . | quote }}
{{- end }}
{{- range $tapGroups }}
  {{- range .items }}
{{ if has . $.packages.darwin.trusted }}brew trust {{ . | quote }} && {{ end -}}
brew tap {{ . | quote }}
{{- end }}
{{- end }}

brew update

{{- $allEnv := dict }}
{{- range $envGroups }}
  {{- range $k, $v := .items }}
    {{- $allEnv = set $allEnv $k $v }}
  {{- end }}
{{- end }}
{{- if $allEnv }}
# Export environment variables required for package installation
  {{- range $k, $v := $allEnv }}
export {{ $k }}={{ $v | quote }}
  {{- end }}
{{- end }}

brew_exit=0
brew bundle --file=/dev/stdin <<'BUNDLE_EOF' || brew_exit=$?
{{- range .packages.darwin.taps }}
tap {{ . | quote }}{{ if has . $.packages.darwin.trusted }}, trusted: true{{ end }}
{{- end }}

{{- $tapByCategory := dict }}
{{- range $tapGroups }}
  {{- $tapByCategory = set $tapByCategory .category .items }}
{{- end }}
{{- $brewByCategory := dict }}
{{- range $brewGroups }}
  {{- $brewByCategory = set $brewByCategory .category .items }}
{{- end }}
{{- $caskByCategory := dict }}
{{- range $caskGroups }}
  {{- $caskByCategory = set $caskByCategory .category .items }}
{{- end }}
{{- $masByCategory := dict }}
{{- range $masGroups }}
  {{- $masByCategory = set $masByCategory .category .items }}
{{- end }}
{{- range $category := prepend .tag_choices "core" }}
  {{- $tapItems := index $tapByCategory $category }}
  {{- $brewItems := index $brewByCategory $category }}
  {{- $caskItems := index $caskByCategory $category }}
  {{- $masItems := index $masByCategory $category }}
  {{- if or $tapItems $brewItems $caskItems $masItems }}

# Install {{ $category }} packages
    {{- if $tapItems }}
{{ range $tapItems -}}
tap {{ . | quote }}{{ if has . $.packages.darwin.trusted }}, trusted: true{{ end }}
{{ end -}}
    {{- end }}

    {{- if $brewItems }}
{{ range $brewItems -}}
brew {{ . | quote }}{{ if has . $.packages.darwin.trusted }}, trusted: true{{ end }}
{{ end -}}
    {{- end }}

    {{- if $caskItems }}
{{ range $caskItems -}}
cask {{ . | quote }}{{ if has . $.packages.darwin.trusted }}, trusted: true{{ end }}
{{ end -}}
    {{- end }}

    {{- if and $icloudSignedIn $masItems }}
{{ range $masItems -}}
mas {{ . }}
{{ end -}}
    {{- end }}
  {{- end }}
{{- end }}
BUNDLE_EOF

if [ "$brew_exit" -ne 0 ]; then
    print_message "warning" "brew bundle completed with errors — some packages may not be installed."
    print_message "info" "Run 'chezmoi apply' again after resolving the issue (e.g., restore network, fix broken cask entry)."
fi

{{ if not $icloudSignedIn -}}
print_message "info" "Sign in to iCloud in System Settings, then run 'chezmoi apply' again to install App Store apps"
{{ end -}}
{{ end -}}
