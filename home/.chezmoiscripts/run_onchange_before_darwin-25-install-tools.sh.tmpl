{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

# run_onchange trigger - packages.yaml changes or every 7 days:  {{ includeTemplate "time-bucket" (dict "days" 7) }}

set -euo pipefail

source "{{ .chezmoi.sourceDir -}}/scripts/shared-utils.sh"

if package_layer_should_skip "uv"; then
    print_message "skip" "Skipping UV tool updates for this run"
    exit 0
fi

if ! require_tools uv; then
    exit 1
fi

print_message "info" "Installing tools using uv..."
# Upgrade all existing tools first
uv tool update --all
{{- $groups := includeTemplate "package-layer-items" (merge (dict "key" "uv") .) | fromJson }}
{{- range $groups }}
# Install {{ .category }} tools
{{ range .items -}}
uv tool install {{ . }}
{{ end -}}
{{- end }}

{{ end -}}
