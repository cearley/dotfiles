{{- if and (eq .chezmoi.os "darwin") (has "ai" .tags) -}}
#!/bin/bash

# run_onchange trigger - packages.yaml changes or every 7 days:  {{ includeTemplate "time-bucket" (dict "days" 7) }}

set -euo pipefail

source "{{ .chezmoi.sourceDir -}}/scripts/shared-utils.sh"

if package_layer_should_skip "claude"; then
    print_message "skip" "Skipping Claude Code skills updates for this run"
    exit 0
fi

# Load nvm so npx is available (installed at position 35)
export NVM_DIR="$HOME/.nvm"
# shellcheck disable=SC1091
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

if ! require_tools npx; then
    exit 1
fi

{{- $claudeCode := index $.packages.darwin.ai.agents "claude_code" }}
{{- $skills := default (list) $claudeCode.skills }}

print_message "info" "Installing Claude Code skills via npx..."

CLAUDE_CONFIG_DIR="$HOME/.claude" npx skills update -g -y
{{- if $skills }}
{{ range $skills -}}
CLAUDE_CONFIG_DIR="$HOME/.claude" npx skills add {{ . }} -g -a claude-code -y
{{ end -}}
{{- end }}

print_message "success" "Claude Code skills installed."

{{ end -}}
